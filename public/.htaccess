RewriteEngine On
RewriteBase /

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove trailing slash
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# Sitemap proxy to edge function
RewriteRule ^sitemap\.xml$ https://uszlfqgxjvceugrpavde.supabase.co/functions/v1/generate-sitemap?type=index [R=301,L]
RewriteRule ^sitemap-pages\.xml$ https://uszlfqgxjvceugrpavde.supabase.co/functions/v1/generate-sitemap?type=pages [R=301,L]
RewriteRule ^sitemap-steden\.xml$ https://uszlfqgxjvceugrpavde.supabase.co/functions/v1/generate-sitemap?type=steden [R=301,L]
RewriteRule ^sitemap-woningen\.xml$ https://uszlfqgxjvceugrpavde.supabase.co/functions/v1/generate-sitemap?type=woningen [R=301,L]
RewriteRule ^sitemap-blog\.xml$ https://uszlfqgxjvceugrpavde.supabase.co/functions/v1/generate-sitemap?type=blog [R=301,L]

# Social crawlers (Facebook/WhatsApp/etc.) krijgen server-side OG metadata per woning
RewriteCond %{REQUEST_URI} ^/woning/[^/]+$ [NC]
RewriteCond %{HTTP_USER_AGENT} (facebook|facebot|meta|twitterbot|linkedinbot|slackbot|discordbot|whatsapp|telegrambot|skypeuripreview) [NC]
RewriteRule ^woning/([^/?]+)$ https://uszlfqgxjvceugrpavde.supabase.co/functions/v1/og-property?slug=$1 [R=302,L]

# SPA fallback - send all requests to index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
